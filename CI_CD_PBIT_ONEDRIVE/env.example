# Copie para .env e preencha. NUNCA commite o .env com valores reais.

# ─── Azure App Registration ────────────────────────────────────────────────────

# Client ID do App Registration
# Onde pegar: portal.azure.com → App registrations → seu app → Application (client) ID
ONEDRIVE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Refresh token obtido rodando: python scripts/get_onedrive_token.py
# Salve o valor gerado aqui e como secret no GitHub
ONEDRIVE_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── OneDrive ─────────────────────────────────────────────────────────────────

# Caminho da pasta no OneDrive onde os .pbit serão salvos
# Exemplo: Dashboards/PBIT  ou  Templates/PowerBI
ONEDRIVE_FOLDER_PATH=Dashboards/PBIT

# ─── Como configurar o App Registration ───────────────────────────────────────
# 1. Acesse portal.azure.com com sua conta Microsoft pessoal
# 2. App registrations → New registration
#    - Supported account types: "Personal Microsoft accounts only"
#    - Redirect URI: Mobile and desktop → http://localhost
# 3. API permissions → Add → Microsoft Graph → Delegated
#    - Files.ReadWrite
#    - offline_access  ← necessário para o refresh token funcionar
# 4. Não precisa de admin consent para conta pessoal
# 5. Rode: python scripts/get_onedrive_token.py
#    para obter o ONEDRIVE_REFRESH_TOKEN
