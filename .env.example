# Copie para .env e preencha. NUNCA commite o .env com valores reais.

# Email da sua conta Power BI (corporativo/universitário)
PBI_USER=seuemail@empresa.com

# Senha da sua conta Power BI
PBI_PASSWORD=sua-senha-aqui

# ID do workspace de destino
# Encontrado na URL: app.powerbi.com/groups/<WORKSPACE_ID>/...
PBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
