# Copie para .env e preencha. NUNCA commite o .env com valores reais.

# Tenant ID do Azure AD (portal.azure.com → Azure Active Directory → Overview)
PBI_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client ID do Service Principal (App Registration → Application ID)
PBI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client Secret do Service Principal (App Registration → Certificates & secrets)
PBI_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ID do Workspace Power BI de destino
# URL: app.powerbi.com/groups/<WORKSPACE_ID>/list
PBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
