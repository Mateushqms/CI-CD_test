# Copie este arquivo para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env com credenciais reais.

# Azure AD — Tenant do Orgão2
PBI_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Service Principal criado no tenant do Orgão2
PBI_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PBI_CLIENT_SECRET=sua-chave-secreta-aqui

# ID do Workspace Power BI de destino (Orgão2)
# Encontrado na URL: app.powerbi.com/groups/<WORKSPACE_ID>/...
PBI_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
