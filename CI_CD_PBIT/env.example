# Copie para .env e preencha. NUNCA commite o .env com valores reais.

# ─── Azure AD ──────────────────────────────────────────────────────────────────

# Tenant ID da organização do Órgão 2
# Onde pegar: portal.azure.com → Azure Active Directory → Overview → "Tenant ID"
SP_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client ID do Service Principal
# Onde pegar: portal.azure.com → App registrations → seleciona o app → "Application (client) ID"
SP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client Secret do Service Principal
# Onde pegar: portal.azure.com → App registrations → Certificates & secrets → New client secret
# Atenção: o valor só aparece uma vez na criação. Copie imediatamente.
SP_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── SharePoint / Graph API ────────────────────────────────────────────────────

# ID do site SharePoint de destino
# Como obter via Graph Explorer:
#   GET https://graph.microsoft.com/v1.0/sites/{hostname}:/{caminho-do-site}
#   Exemplo: GET https://graph.microsoft.com/v1.0/sites/orgao2.sharepoint.com:/sites/Dashboards
#   O campo "id" da resposta é o SP_SITE_ID
SP_SITE_ID=orgao2.sharepoint.com,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx,xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ID da biblioteca de documentos (Drive) dentro do site
# Como obter:
#   GET https://graph.microsoft.com/v1.0/sites/{SP_SITE_ID}/drives
#   Escolha a biblioteca correta pelo campo "name" e copie o "id"
SP_DRIVE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Caminho da pasta dentro da biblioteca onde os .pbit serão salvos
# Exemplo: Dashboards/PowerBI  ou  Geral/Templates
SP_FOLDER_PATH=Dashboards/PowerBI

# ─── Permissões necessárias no App Registration ────────────────────────────────
# Tipo: Application (não Delegated)
#   - Files.ReadWrite.All
#   - Sites.ReadWrite.All
# Após adicionar, clicar em "Grant admin consent"
